{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "IM",
  "version": "0.1.0",
  "identifier": "com.im.app",
  "build": {
    "frontendDist": "../dist/client/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "IM",
        "width": 960,
        "height": 680,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
